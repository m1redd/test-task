    "format:check": "prettier --check 'src/**/*.ts'",
    "test": "jest --passWithNoTests"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
